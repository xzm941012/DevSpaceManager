<Window x:Class="DevSpaceManager.UI.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="检查更新"
        Width="640"
        Height="430"
        MinWidth="560"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#FAFAF8">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#20201D" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E9E9E6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#20201D" />
            <Setter Property="BorderBrush" Value="#20201D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33332E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#D6D6D0" />
                                <Setter Property="BorderBrush" Value="#D6D6D0" />
                                <Setter Property="Foreground" Value="#7D7D76" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8D8D3" />
            <Setter Property="Foreground" Value="#20201D" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F1" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#BFBFBA" BorderThickness="1" Background="#FAFAF8" CornerRadius="8">
        <Grid Margin="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#F9F9F9" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <TextBlock Text="检查更新"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#20201D" />
                <Button Width="46"
                        Height="35"
                        HorizontalAlignment="Right"
                        Click="CloseButton_OnClick"
                        Style="{StaticResource CloseButtonStyle}">
                    <Path Width="10"
                          Height="10"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Stretch="Uniform"
                          Data="M18 6 6 18 M6 6l12 12" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="24,20,24,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="本地组件"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#20201D" />
                <TextBlock Grid.Row="1"
                           Text="检查 DevSpace 和 Cloudflare Tunnel 工具版本。"
                           Margin="0,6,0,16"
                           FontSize="12.5"
                           Foreground="#6F6F68" />

                <StackPanel Grid.Row="2">
                    <Border BorderBrush="#E3E3DE" BorderThickness="0,0,0,1" Padding="0,13">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="DevSpace"
                                           FontSize="13.5"
                                           FontWeight="SemiBold"
                                           Foreground="#20201D" />
                                <TextBlock x:Name="DevSpaceVersionText"
                                           Text="当前版本：正在检查..."
                                           Margin="0,4,0,0"
                                           FontSize="12.2"
                                           Foreground="#6F6F68"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="DevSpaceNotesText"
                                           Text=""
                                           Margin="0,4,0,0"
                                           FontSize="12.2"
                                           Foreground="#6F6F68"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button x:Name="UpdateDevSpaceButton"
                                    Grid.Column="1"
                                    Content="更新"
                                    VerticalAlignment="Center"
                                    Click="UpdateDevSpaceButton_OnClick"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                    </Border>

                    <Border BorderBrush="#E3E3DE" BorderThickness="0,0,0,1" Padding="0,13">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="cloudflared"
                                           FontSize="13.5"
                                           FontWeight="SemiBold"
                                           Foreground="#20201D" />
                                <TextBlock x:Name="CloudflaredVersionText"
                                           Text="当前版本：正在检查..."
                                           Margin="0,4,0,0"
                                           FontSize="12.2"
                                           Foreground="#6F6F68"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="CloudflaredNotesText"
                                           Text=""
                                           Margin="0,4,0,0"
                                           FontSize="12.2"
                                           Foreground="#6F6F68"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button x:Name="UpdateCloudflaredButton"
                                    Grid.Column="1"
                                    Content="更新"
                                    VerticalAlignment="Center"
                                    Click="UpdateCloudflaredButton_OnClick"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                    </Border>

                    <TextBlock x:Name="StatusText"
                               Margin="0,16,0,0"
                               FontSize="12.5"
                               Foreground="#6F6F68"
                               Text="准备检查更新。" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" BorderBrush="#E3E3DE" BorderThickness="0,1,0,0" Background="#FAFAF8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0">
                    <Button x:Name="CheckButton"
                            Content="检查更新"
                            Margin="0,0,10,0"
                            Click="CheckButton_OnClick"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="关闭"
                            Click="CloseButton_OnClick"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
