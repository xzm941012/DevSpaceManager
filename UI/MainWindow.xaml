<Window x:Class="DevSpaceManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="DevSpace"
        Width="1380"
        Height="860"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="#FAFAF8">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#6F6F68" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8E8E5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#B8B8B2" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleIconStyle" TargetType="Path">
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#20201D" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E9E9E6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ErrorRefreshButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#20201D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#20201D" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F6F6F3" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EEEEEA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeMenuItemStyle" TargetType="MenuItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="MinWidth" Value="52" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#20201D" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="TopBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <TextBlock x:Name="HeaderText"
                                               Text="{TemplateBinding Header}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}" />
                                    <TextBlock x:Name="SubmenuText"
                                               Text="{TemplateBinding Header}"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Foreground="#20201D"
                                               Visibility="Collapsed" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Grid Background="Transparent" Margin="0,4,8,10">
                                    <Border Background="#FFFFFFFF"
                                            BorderBrush="#D8D8D3"
                                            BorderThickness="1"
                                            CornerRadius="7"
                                            Padding="0,6"
                                            MinWidth="88"
                                            SnapsToDevicePixels="True">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="18"
                                                              ShadowDepth="2"
                                                              Opacity="0.16"
                                                              Color="#000000" />
                                        </Border.Effect>
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="TopBorder" Property="Background" Value="#E8E8E5" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter Property="Padding" Value="14,0" />
                                <Setter Property="MinWidth" Value="104" />
                                <Setter Property="Height" Value="32" />
                                <Setter Property="Foreground" Value="#20201D" />
                                <Setter TargetName="TopBorder" Property="HorizontalAlignment" Value="Stretch" />
                                <Setter TargetName="TopBorder" Property="CornerRadius" Value="0" />
                                <Setter TargetName="HeaderText" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="SubmenuText" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#A8A8A1" />
                                <Setter TargetName="HeaderText" Property="Foreground" Value="#A8A8A1" />
                                <Setter TargetName="SubmenuText" Property="Foreground" Value="#A8A8A1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeMenuStyle" TargetType="Menu">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#6F6F68" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ChromeMenuItemStyle}" />
        </Style>

        <Style x:Key="ChromeMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Height" Value="9" />
            <Setter Property="Width" Value="64" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Background="#E1E1DC"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeToolTipStyle" TargetType="ToolTip">
            <Setter Property="Placement" Value="Bottom" />
            <Setter Property="HorizontalOffset" Value="-8" />
            <Setter Property="VerticalOffset" Value="4" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Grid Background="Transparent" Margin="0,0,10,10">
                            <Border Background="#FFFFFFFF"
                                    BorderBrush="#D8D8D3"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Padding="10,8"
                                    MaxWidth="240"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18"
                                                      ShadowDepth="2"
                                                      Opacity="0.16"
                                                      Color="#000000" />
                                </Border.Effect>
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Grid Background="#FAFAF8" Margin="0">
        <Border BorderBrush="#BFBFBA" BorderThickness="1" Background="#FAFAF8" CornerRadius="8">
            <Grid Margin="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#f9f9f9" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            x:Name="ChromeNavigation"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0"
                            Visibility="Collapsed"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="BackButton"
                            ToolTip="后退"
                            Click="BackButton_OnClick"
                            Width="26"
                            Height="26"
                            Margin="0,0,1,0"
                            Style="{StaticResource ChromeButtonStyle}">
                        <Path Style="{StaticResource TitleIconStyle}" Data="M15 18l-6-6 6-6 M9 12h12" />
                    </Button>
                    <Button x:Name="ForwardButton"
                            ToolTip="前进"
                            Click="ForwardButton_OnClick"
                            Width="26"
                            Height="26"
                            Margin="0,0,1,0"
                            Style="{StaticResource ChromeButtonStyle}">
                        <Path Style="{StaticResource TitleIconStyle}" Data="M9 18l6-6-6-6 M15 12H3" />
                    </Button>
                    <Button ToolTip="刷新 ChatGPT"
                            Click="RefreshButton_OnClick"
                            Width="26"
                            Height="26"
                            Margin="0,0,1,0"
                            Style="{StaticResource ChromeButtonStyle}">
                        <Path Style="{StaticResource TitleIconStyle}" Data="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16 M3 21v-5h5 M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8 M21 3v5h-5" />
                    </Button>
                    <Button x:Name="EnvironmentWarningButton"
                            Click="EnvironmentWarningButton_OnClick"
                            Width="26"
                            Height="26"
                            Margin="0,0,12,0"
                            Foreground="#B7791F"
                            Visibility="Collapsed"
                            ToolTipService.InitialShowDelay="0"
                            ToolTipService.BetweenShowDelay="0"
                            ToolTipService.ShowDuration="6000"
                            Style="{StaticResource ChromeButtonStyle}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource ChromeToolTipStyle}">
                                <StackPanel Orientation="Horizontal">
                                        <Grid Width="14" Height="14" Margin="0,1,7,0">
                                            <Path Fill="#F2C94C"
                                                  Stroke="#A86F00"
                                                  StrokeThickness="0.45"
                                                  Stretch="Uniform"
                                                  Data="M21.73 18 13.73 4a2 2 0 0 0-3.46 0L2.27 18A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" />
                                            <Path Width="5"
                                                  Height="8"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="0,2,0,0"
                                                  Stroke="#5F4200"
                                                  StrokeThickness="2.2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Fill="Transparent"
                                                  Stretch="Uniform"
                                                  Data="M12 8v5 M12 17h.01" />
                                        </Grid>
                                    <StackPanel>
                                        <TextBlock Text="环境需要处理"
                                                   Foreground="#20201D"
                                                   FontSize="12.5"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="EnvironmentWarningToolTipText"
                                                   Text="点击查看并处理"
                                                   Margin="0,2,0,0"
                                                   Foreground="#6F6F68"
                                                   FontSize="11.5"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </ToolTip>
                        </Button.ToolTip>
                        <Grid Width="14" Height="14">
                            <Path Fill="#F2C94C"
                                  Stroke="#A86F00"
                                  StrokeThickness="0.45"
                                  Stretch="Uniform"
                                  Data="M21.73 18 13.73 4a2 2 0 0 0-3.46 0L2.27 18A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" />
                            <Path Width="5"
                                  Height="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="0,2,0,0"
                                  Stroke="#5F4200"
                                  StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Data="M12 8v5 M12 17h.01" />
                        </Grid>
                    </Button>
                    <Button x:Name="UpdateAvailableButton"
                            Click="UpdateAvailableButton_OnClick"
                            Width="26"
                            Height="26"
                            Margin="0,0,12,0"
                            Foreground="#FFFFFF"
                            Visibility="Collapsed"
                            ToolTipService.InitialShowDelay="0"
                            ToolTipService.BetweenShowDelay="0"
                            ToolTipService.ShowDuration="6000"
                            Style="{StaticResource ChromeButtonStyle}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource ChromeToolTipStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="14" Height="14" Margin="0,1,7,0">
                                        <Ellipse Fill="#22A06B" />
                                        <Path Width="8"
                                              Height="8"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Stroke="#FFFFFF"
                                              StrokeThickness="1.7"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"
                                              Stretch="Uniform"
                                              Data="M12 19V5 M5 12l7-7 7 7" />
                                    </Grid>
                                    <StackPanel>
                                        <TextBlock Text="发现可用更新"
                                                   Foreground="#20201D"
                                                   FontSize="12.5"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="UpdateAvailableToolTipText"
                                                   Text="点击打开检查更新"
                                                   Margin="0,2,0,0"
                                                   Foreground="#6F6F68"
                                                   FontSize="11.5"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </ToolTip>
                        </Button.ToolTip>
                        <Grid Width="14" Height="14">
                            <Ellipse Fill="#22A06B" />
                            <Path Width="8"
                                  Height="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Stroke="#FFFFFF"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Data="M12 19V5 M5 12l7-7 7 7" />
                        </Grid>
                    </Button>
                    <Menu Background="Transparent"
                          BorderThickness="0"
                          VerticalAlignment="Center"
                          Style="{StaticResource ChromeMenuStyle}">
                        <Menu.Resources>
                            <Style TargetType="MenuItem" BasedOn="{StaticResource ChromeMenuItemStyle}" />
                            <Style TargetType="Separator" BasedOn="{StaticResource ChromeMenuSeparatorStyle}" />
                        </Menu.Resources>
                        <MenuItem Header="文件" Foreground="#6F6F68" Style="{StaticResource ChromeMenuItemStyle}">
                            <MenuItem Header="设置" Click="SettingsMenuItem_OnClick" />
                            <MenuItem Header="环境设置" Click="EnvironmentSetupMenuItem_OnClick" />
                            <Separator Style="{StaticResource ChromeMenuSeparatorStyle}" />
                            <MenuItem Header="退出" Click="ExitMenuItem_OnClick" />
                        </MenuItem>
                        <MenuItem Header="编辑" Foreground="#6F6F68" Style="{StaticResource ChromeMenuItemStyle}">
                            <MenuItem Header="Undo    Ctrl+Z" Command="ApplicationCommands.Undo" />
                            <MenuItem Header="Redo    Ctrl+Y" Command="ApplicationCommands.Redo" />
                            <Separator Style="{StaticResource ChromeMenuSeparatorStyle}" />
                            <MenuItem Header="Cut       Ctrl+X" Command="ApplicationCommands.Cut" />
                            <MenuItem Header="Copy     Ctrl+C" Command="ApplicationCommands.Copy" />
                            <MenuItem Header="Paste    Ctrl+V" Command="ApplicationCommands.Paste" />
                            <MenuItem Header="Delete" Command="ApplicationCommands.Delete" />
                            <Separator Style="{StaticResource ChromeMenuSeparatorStyle}" />
                            <MenuItem Header="Select All  Ctrl+A" Command="ApplicationCommands.SelectAll" />
                        </MenuItem>
                        <MenuItem Header="视图" Foreground="#6F6F68" Style="{StaticResource ChromeMenuItemStyle}">
                            <MenuItem Header="刷新 ChatGPT" Click="RefreshMenuItem_OnClick" />
                            <MenuItem Header="打开 ChatGPT 首页" Click="OpenChatGptMenuItem_OnClick" />
                        </MenuItem>
                        <MenuItem Header="帮助" Foreground="#6F6F68" Style="{StaticResource ChromeMenuItemStyle}">
                            <MenuItem Header="设置与诊断" Click="SettingsMenuItem_OnClick" />
                            <MenuItem Header="环境配置" Click="EnvironmentSetupMenuItem_OnClick" />
                        </MenuItem>
                    </Menu>
                </StackPanel>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Width="46"
                            Height="35"
                            Click="MinimizeButton_OnClick"
                            Style="{StaticResource WindowControlButtonStyle}">
                        <Path Style="{StaticResource TitleIconStyle}" Width="10" Height="10" Data="M5 12h14" />
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Width="46"
                            Height="35"
                            Click="MaximizeButton_OnClick"
                            Style="{StaticResource WindowControlButtonStyle}">
                        <Path x:Name="MaximizeIcon" Style="{StaticResource TitleIconStyle}" Width="10" Height="10" Data="M5 5h14v14H5z" />
                    </Button>
                    <Button Width="46"
                            Height="35"
                            Click="CloseButton_OnClick"
                            Style="{StaticResource CloseWindowButtonStyle}">
                        <Path Style="{StaticResource TitleIconStyle}" Width="10" Height="10" Data="M18 6 6 18 M6 6l12 12" />
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="0"
                        ClipToBounds="True">
                    <Grid x:Name="ChatGptHost" />
                </Border>

                <Grid x:Name="ChatGptLoadingOverlay"
                      Grid.Column="0"
                      Panel.ZIndex="20"
                      Background="#FFFFFF"
                      Visibility="Visible"
                      IsHitTestVisible="False">
                    <Grid Width="104"
                          Height="104"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <Grid ClipToBounds="True">
                            <Image Source="pack://application:,,,/assets/chatgpt-logo-official-black-transparent.png"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="Fill" />
                            <Rectangle x:Name="LoadingGlowBand"
                                       Opacity="1">
                                <Rectangle.Effect>
                                    <BlurEffect Radius="10" />
                                </Rectangle.Effect>
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <LinearGradientBrush.RelativeTransform>
                                            <TranslateTransform X="-0.72" />
                                        </LinearGradientBrush.RelativeTransform>
                                        <GradientStop Color="#00000000" Offset="0" />
                                        <GradientStop Color="#4DFFFFFF" Offset="0.32" />
                                        <GradientStop Color="#FFFFFFFF" Offset="0.45" />
                                        <GradientStop Color="#FFFFFFFF" Offset="0.50" />
                                        <GradientStop Color="#FFFFFFFF" Offset="0.55" />
                                        <GradientStop Color="#4DFFFFFF" Offset="0.68" />
                                        <GradientStop Color="#00000000" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="pack://application:,,,/assets/chatgpt-logo-official-black-transparent.png"
                                                Stretch="Fill" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </Grid>
                    </Grid>
                </Grid>

                <Grid x:Name="ChatGptErrorOverlay"
                      Grid.Column="0"
                      Panel.ZIndex="30"
                      Background="#FFFFFF"
                      Visibility="Collapsed">
                    <StackPanel x:Name="ChatGptErrorContent"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <TextBlock Text="页面加载出错，请检查网络是否异常并刷新页面"
                                   HorizontalAlignment="Center"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#20201D" />
                        <Button Width="92"
                                HorizontalAlignment="Center"
                                Margin="0,18,0,0"
                                Click="ErrorRefreshButton_OnClick"
                                Style="{StaticResource ErrorRefreshButtonStyle}">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Path Width="13"
                                      Height="13"
                                      Margin="0,0,7,0"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.25"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Stretch="Uniform"
                                      Data="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16 M3 21v-5h5 M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8 M21 3v5h-5" />
                                <TextBlock Text="刷新" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
